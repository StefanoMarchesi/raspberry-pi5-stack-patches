@@ -3879,6 +3867,12 @@ v3dv_CmdBindDescriptorSets(VkCommandBuffer commandBuffer,
       V3DV_FROM_HANDLE(v3dv_descriptor_set, set, pDescriptorSets[i]);
       uint32_t index = firstSet + i;
 
+      /* Binding a regular descriptor set to this set number disturbs any
+       * descriptors previously pushed to the same set number, so drop our
+       * accumulation tracking for it (a subsequent push must start fresh).
+       */
+      cmd_buffer->push_descriptor.sets[index] = NULL;
