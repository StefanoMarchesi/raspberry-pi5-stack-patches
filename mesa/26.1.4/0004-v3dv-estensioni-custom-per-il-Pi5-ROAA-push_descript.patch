+/* VK_EXT_rasterization_order_attachment_access (color)
+ *
+ * When a subpass color attachment is aliased by an input attachment and the
+ * pipeline was created with
+ * VK_PIPELINE_COLOR_BLEND_STATE_CREATE_RASTERIZATION_ORDER_ATTACHMENT_ACCESS_BIT_EXT,
+ * loads from that input attachment must observe, in rasterization order, the
+ * color writes of all overlapping fragments rasterized earlier, without any
+ * pipeline barrier between them.
+ *
+ * On V3D we get this guarantee for free from the TLB: TLB color reads are
+ * always executed after the per-pixel scoreboard lock has been acquired (see
+ * vir_emit_tlb_color_read() in nir_to_vir.c), which serializes overlapping
+ * fragments in rasterization order. This is the same mechanism the GL driver
+ * uses for coherent framebuffer fetch and that we already use for software
+ * blending (dual-source blend).
+ *
+ * So, instead of lowering these input attachment loads to texel fetches from
+ * memory (which within the render pass would return stale data since the
+ * current color values live in the tile buffer), we lower them to
+ * nir_load_tlb_color_brcm intrinsics on the aliased render target.
+ *
+ * This pass must run *before* pipeline_lower_nir(), while the texel fetches
+ * produced by nir_lower_input_attachments() still carry a texture deref to
+ * the original input attachment variable (whose data.index holds the input
+ * attachment index).
+ */
+/* State threaded through the input-attachment lowering callback so we can
+ * record which render targets the fragment shader actually reads (as opposed
+ * to the ones that are merely aliased in roaa_map).
+ */
+struct roaa_lower_state {
+   struct v3dv_pipeline *pipeline;
+   uint32_t read_rts;
+};
+
+static nir_def *
+roaa_load_tlb_color(nir_builder *b, unsigned rt, unsigned sample)
+{
+   nir_def *comps[4];
+   for (unsigned i = 0; i < 4; i++) {
+      comps[i] = nir_load_tlb_color_brcm(b, 1, 32, nir_imm_int(b, rt),
+                                         .base = sample, .component = i);
+   }
+   return nir_vec(b, comps, 4);
+}
+
+/* For 16-bit normalized formats the TLB read returns the raw integer values
+ * (these RTs are marked f32_color_rb in the FS key, see
+ * v3d_fs_key_set_color_attachment()), so we need to convert them to float,
+ * mirroring what lower_16bit_norm() in vir.c does for load_output. We use the
+ * portable software conversion helpers, which are correct on all HW versions.
+ */
+static nir_def *
+roaa_convert_norm16(nir_builder *b, struct v3dv_pipeline *pipeline,
+                    unsigned rt, nir_def *out)
+{
+   VkFormat vk_format = pipeline->rendering_info.color_attachment_formats[rt];
+   assert(vk_format != VK_FORMAT_UNDEFINED);
+   const struct util_format_description *desc = vk_format_description(vk_format);
+   if ((desc->is_unorm || desc->is_snorm) && desc->channel[0].size == 16) {
+      static const unsigned bits_16[4] = {16, 16, 16, 16};
+      out = desc->is_snorm ? nir_format_snorm_to_float(b, out, bits_16) :
+                             nir_format_unorm_to_float(b, out, bits_16);
+   }
+   return out;
+}
+
+static bool
+lower_roaa_input_attachment_cb(nir_builder *b, nir_instr *instr, void *data)
+{
+   struct roaa_lower_state *state = data;
+   struct v3dv_pipeline *pipeline = state->pipeline;
+
+   if (instr->type != nir_instr_type_tex)
+      return false;
+
+   nir_tex_instr *tex = nir_instr_as_tex(instr);
+   if (tex->op != nir_texop_txf)
+      return false;
+
+   /* Input attachment loads keep their subpass sampler dim after
+    * nir_lower_input_attachments().
+    */
+   if (tex->sampler_dim != GLSL_SAMPLER_DIM_SUBPASS &&
+       tex->sampler_dim != GLSL_SAMPLER_DIM_SUBPASS_MS)
+      return false;
+
+   /* Sparse loads and non 32-bit destinations keep the memory path */
+   if (tex->is_sparse || tex->def.bit_size != 32)
+      return false;
+
+   int deref_idx = nir_tex_instr_src_index(tex, nir_tex_src_texture_deref);
+   if (deref_idx < 0)
+      return false;
+
+   nir_deref_instr *deref = nir_src_as_deref(tex->src[deref_idx].src);
+   nir_variable *var = nir_deref_instr_get_variable(deref);
+   if (!var)
+      return false;
+
+   /* var->data.index is the InputAttachmentIndex decoration. For arrays of
+    * subpass inputs we can only handle constant indexing; dynamic indexing
+    * keeps the memory path.
+    */
+   uint32_t ia_index = var->data.index;
+   if (deref->deref_type == nir_deref_type_array) {
+      if (!nir_src_is_const(deref->arr.index))
+         return false;
+      ia_index += nir_src_as_uint(deref->arr.index);
+   }
+
+   if (ia_index >= ARRAY_SIZE(pipeline->roaa_map))
+      return false;
+
+   const uint8_t rt = pipeline->roaa_map[ia_index];
+   if (rt == V3DV_ROAA_UNUSED)
+      return false;
+
+   assert(rt < V3D_MAX_DRAW_BUFFERS);
+
+   /* Record that the shader really reads this RT through the TLB, so we can
+    * make sure a matching TLB color *write* is emitted for it (which is what
+    * releases the per-pixel scoreboard lock the read acquired).
+    */
+   state->read_rts |= 1u << rt;
+
+   b->cursor = nir_before_instr(instr);
+
+   /* Input attachment reads are only defined at the current fragment
+    * location (x, y, layer), which is exactly what the TLB read returns,
+    * so we can ignore the texel coordinates here.
+    *
+    * For multisampled targets the TLB holds all the samples of the
+    * current pixel and nir_load_tlb_color_brcm selects one with its base
+    * index, so we honor the sample index requested by the shader with a
+    * select chain (the backend reads all the samples from the TLB on the
+    * first read and caches them, so the extra loads are just MOVs).
+    */
+   nir_def *out = roaa_load_tlb_color(b, rt, 0);
+   if (pipeline->msaa) {
+      int ms_idx = nir_tex_instr_src_index(tex, nir_tex_src_ms_index);
+      if (ms_idx >= 0) {
+         nir_def *sample = tex->src[ms_idx].src.ssa;
+         for (unsigned i = 1; i < V3D_MAX_SAMPLES; i++) {
+            out = nir_bcsel(b, nir_ieq_imm(b, sample, i),
+                            roaa_load_tlb_color(b, rt, i), out);
+         }
+      }
+   }
+
+   out = roaa_convert_norm16(b, pipeline, rt, out);
+
+   if (tex->def.num_components < 4)
+      out = nir_trim_vector(b, out, tex->def.num_components);
+
+   b->shader->info.fs.uses_fbfetch_output = true;
+
+   nir_def_replace(&tex->def, out);
+   return true;
+}
+
+/* Returns the mask of color render targets the fragment shader already writes
+ * (has a real store to), so we don't add a redundant pseudo-write that would
+ * clobber the application's output. At this point in the pipeline (before
+ * lower_fs_io()) fragment outputs are still variable stores (store_deref);
+ * we also handle store_output defensively.
+ */
+static uint32_t
+roaa_written_rts(nir_shader *nir)
+{
+   uint32_t written = 0;
+
+   nir_foreach_function_impl(impl, nir) {
+      nir_foreach_block(block, impl) {
+         nir_foreach_instr(instr, block) {
+            if (instr->type != nir_instr_type_intrinsic)
+               continue;
+
+            nir_intrinsic_instr *intr = nir_instr_as_intrinsic(instr);
+            int location = -1;
+
+            if (intr->intrinsic == nir_intrinsic_store_deref) {
+               nir_variable *var =
+                  nir_deref_instr_get_variable(nir_src_as_deref(intr->src[0]));
+               if (var && var->data.mode == nir_var_shader_out &&
+                   var->data.index == 0)
+                  location = var->data.location;
+            } else if (intr->intrinsic == nir_intrinsic_store_output) {
+               location = nir_intrinsic_io_semantics(intr).location;
+            }
+
+            if (location >= FRAG_RESULT_DATA0 &&
+                location <= FRAG_RESULT_DATA7)
+               written |= 1u << (location - FRAG_RESULT_DATA0);
+         }
+      }
+   }
+
+   return written;
+}
+
+/* Finds the existing nir_var_shader_out for a given color RT, or creates one
+ * (a plain vec4 FRAG_RESULT_DATA0+rt output) if none exists.
+ */
+static nir_variable *
+roaa_get_or_create_output(nir_shader *nir, unsigned rt)
+{
+   nir_foreach_shader_out_variable(var, nir) {
+      if (var->data.index == 0 &&
+          var->data.location == (int)(FRAG_RESULT_DATA0 + rt))
+         return var;
+   }
+
+   char name[16];
+   snprintf(name, sizeof(name), "roaa_out%u", rt);
+   nir_variable *var =
+      nir_variable_create(nir, nir_var_shader_out, glsl_vec4_type(), name);
+   var->data.location = FRAG_RESULT_DATA0 + rt;
+   var->data.index = 0;
+   return var;
+}
+
+static void
+lower_roaa_input_attachments(nir_shader *nir, struct v3dv_pipeline *pipeline)
+{
+   assert(nir->info.stage == MESA_SHADER_FRAGMENT);
+
+   bool any_aliased = false;
+   for (unsigned i = 0; i < ARRAY_SIZE(pipeline->roaa_map); i++)
+      any_aliased |= pipeline->roaa_map[i] != V3DV_ROAA_UNUSED;
+
+   if (!any_aliased)
+      return;
+
+   struct roaa_lower_state state = {
+      .pipeline = pipeline,
+      .read_rts = 0,
+   };
+
+   bool progress = false;
+   NIR_PASS(progress, nir, nir_shader_instructions_pass,
+            lower_roaa_input_attachment_cb, nir_metadata_control_flow,
+            &state);
+
+   if (!progress)
+      return;
+
+   /* Clean up the dead derefs so descriptor lowering doesn't see them */
+   NIR_PASS(_, nir, nir_opt_dce);
+
+   /* On V3D a fragment shader that does a TLB color *read* acquires the
+    * per-pixel scoreboard lock, and that lock is only released by a TLB color
+    * *write* (vir_emit_tlb_color_write(), driven by a store_output). Every
+    * proven TLB-read consumer (GL framebuffer fetch, v3dv software blending)
+    * also writes the render target, so the lock is always released.
+    *
+    * VK_EXT_rasterization_order_attachment_access lets a shader read a color
+    * attachment (through an aliased input attachment) that it never writes.
+    * Without a matching color write the scoreboard lock is acquired but never
+    * released and the GPU hangs (V3D_ERR_STAT bit 12).
+    *
+    * So for every RT we turned into a TLB read but the shader does not
+    * already write, synthesize a color output that writes the value we just
+    * read back to the TLB. This is a content-preserving (identity) write --
+    * exactly what software blending does with an identity blend function --
+    * so it cannot corrupt the attachment, while still emitting the TLB write
+    * that releases the scoreboard lock and setting up the per-RT TLB config
+    * and threading identically to the proven software_blend path.
+    */
+   uint32_t written = roaa_written_rts(nir);
+   uint32_t pending = state.read_rts & ~written;
+
+   if (pending) {
+      nir_function_impl *impl = nir_shader_get_entrypoint(nir);
+      nir_builder b = nir_builder_at(nir_after_impl(impl));
+
+      u_foreach_bit(rt, pending) {
+         nir_variable *var = roaa_get_or_create_output(nir, rt);
+         nir_def *val = roaa_convert_norm16(&b, pipeline, rt,
+                                            roaa_load_tlb_color(&b, rt, 0));
+         nir_store_var(&b, var, val, 0xf);
+      }
+
+      nir->info.fs.uses_fbfetch_output = true;
+      nir_progress(true, impl, nir_metadata_control_flow);
+   }
+}
+
+/* Fills pipeline->roaa_map. Only pipelines created against a render pass
+ * object can use rasterization order attachment access on this driver:
+ * with dynamic rendering, input attachments would require
+ * VK_KHR_dynamic_rendering_local_read, which we don't support.
+ */
+static void
+pipeline_setup_roaa_map(struct v3dv_pipeline *pipeline,
+                        const VkGraphicsPipelineCreateInfo *pCreateInfo)
+{
+   memset(pipeline->roaa_map, V3DV_ROAA_UNUSED, sizeof(pipeline->roaa_map));
+
+   if (!pipeline->pass || !pipeline->subpass)
+      return;
+
+   /* pColorBlendState must be ignored when rasterization is disabled */
+   if (!pipeline->rasterization_enabled)
+      return;
+
+   const VkPipelineColorBlendStateCreateInfo *cb = pCreateInfo->pColorBlendState;
+   if (!cb ||
+       !(cb->flags &
+         VK_PIPELINE_COLOR_BLEND_STATE_CREATE_RASTERIZATION_ORDER_ATTACHMENT_ACCESS_BIT_EXT)) {
+      return;
+   }
+
+   const struct v3dv_subpass *subpass = pipeline->subpass;
+   for (uint32_t i = 0; i < subpass->input_count; i++) {
+      if (i >= ARRAY_SIZE(pipeline->roaa_map))
+         break;
+
+      const uint32_t att = subpass->input_attachments[i].attachment;
+      if (att == VK_ATTACHMENT_UNUSED)
+         continue;
+
+      for (uint32_t j = 0; j < subpass->color_count; j++) {
+         if (subpass->color_attachments[j].attachment == att) {
+            pipeline->roaa_map[i] = j;
+            break;
+         }
+      }
+   }
+}
