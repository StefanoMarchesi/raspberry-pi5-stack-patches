    assert(pCreateInfo->sType == VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO);
 
+   /* VK_KHR_push_descriptor: we support layouts created with
+    * VK_DESCRIPTOR_SET_LAYOUT_CREATE_PUSH_DESCRIPTOR_BIT. There is nothing
+    * special to do here at layout creation time: the flag is stored in
+    * set_layout->flags and descriptor sets with these layouts are allocated
+    * internally, from a per-command buffer descriptor pool, when descriptors
+    * are pushed to a command buffer (see v3dv_CmdPushDescriptorSet2KHR).
+    */
+   ASSERTED const bool push_descriptor_layout =
+      pCreateInfo->flags & VK_DESCRIPTOR_SET_LAYOUT_CREATE_PUSH_DESCRIPTOR_BIT;
+
    uint32_t num_bindings = 0;
    uint32_t immutable_sampler_count = 0;
 
@@ -818,6 +828,15 @@ v3dv_CreateDescriptorSetLayout(VkDevice _device,
 
    free(bindings);
 
+   /* From the Vulkan spec, push descriptor set layouts can't include dynamic
+    * buffers or inline uniform blocks and can't exceed maxPushDescriptors.
+    * Enforcing this is the application's responsibility, we just sanity-check
+    * it on debug builds.
+    */
+   assert(!push_descriptor_layout ||
+          (dynamic_offset_count == 0 &&
+           descriptor_count <= MAX_PUSH_DESCRIPTORS));
+
    set_layout->descriptor_count = descriptor_count;
    set_layout->dynamic_offset_count = dynamic_offset_count;
 
@@ -963,6 +982,26 @@ descriptor_set_create(struct v3dv_device *device,
       }
    }
 
+   /* Defensive hardening: initialize the descriptor type of every slot from
+    * the layout. Descriptor sets are otherwise zero-initialized, so an
+    * unwritten slot reports type 0 (VK_DESCRIPTOR_TYPE_SAMPLER), which makes
+    * the recorded descriptor state ambiguous if a shader ever reads a slot
+    * that was never written (which is undefined behavior per the Vulkan spec).
+    * This does not by itself make sampling an unwritten slot valid (the
+    * image_view/buffer_view pointers are still NULL), but keeps the stored
+    * descriptor type consistent with the layout for anything that inspects it.
+    */
+   for (uint32_t b = 0; b < layout->binding_count; b++) {
+      const struct v3dv_descriptor_set_binding_layout *bl = &layout->binding[b];
+      /* Inline uniform blocks encode their byte size in array_size but only
+       * occupy a single descriptor slot, so clamp to one entry for them.
+       */
+      uint32_t slots = bl->type == VK_DESCRIPTOR_TYPE_INLINE_UNIFORM_BLOCK ?
+                       1 : bl->array_size;
+      for (uint32_t i = 0; i < slots; i++)
+         set->descriptors[bl->descriptor_index + i].type = bl->type;
+   }
+
    v3dv_descriptor_set_layout_ref(layout);
    list_addtail(&set->pool_link, &pool->set_list);
 
@@ -1208,14 +1247,25 @@ v3dv_UpdateDescriptorSets(VkDevice  _device,
             break;
          }
          case VK_DESCRIPTOR_TYPE_SAMPLER: {
-            /* If we are here we shouldn't be modifying an immutable sampler */
-            assert(!binding_layout->immutable_samplers_offset);
-            const VkDescriptorImageInfo *image_info = writeset->pImageInfo + j;
-            V3DV_FROM_HANDLE(v3dv_sampler, sampler, image_info->sampler);
+            /* If the binding uses immutable samplers, the sampler handle in
+             * the write is ignored per the Vulkan spec: the immutable sampler
+             * was already baked into the set's BO at set-creation time (see
+             * the immutable-sampler copy in descriptor_set_create). A regular
+             * descriptor set never reaches this path because the spec forbids
+             * the app from writing the sampler of an immutable-sampler binding,
+             * but push descriptor sets funnel the app's writes through
+             * v3dv_UpdateDescriptorSets, where such a write is legal and must
+             * be a no-op for the sampler. Skip overwriting it (and don't deref
+             * the ignored, possibly VK_NULL_HANDLE, sampler handle).
+             */
+            if (!binding_layout->immutable_samplers_offset) {
+               const VkDescriptorImageInfo *image_info = writeset->pImageInfo + j;
+               V3DV_FROM_HANDLE(v3dv_sampler, sampler, image_info->sampler);
 
-            write_image_descriptor(device, descriptor, writeset->descriptorType,
-                                   set, binding_layout, NULL, sampler,
-                                   writeset->dstArrayElement + j);
+               write_image_descriptor(device, descriptor, writeset->descriptorType,
+                                      set, binding_layout, NULL, sampler,
+                                      writeset->dstArrayElement + j);
+            }
 
             break;
          }
