@@ -657,6 +657,41 @@ struct v3dv_cmd_buffer {
       } query;
    } meta;
 
+   /* Per-command buffer resources for VK_KHR_push_descriptor.
+    *
+    * This is the current descriptor pool from which we allocate the internal
+    * descriptor sets backing vkCmdPushDescriptorSet(2)(KHR). It grows on
+    * demand: when it is exhausted we simply create a new, larger pool. All
+    * these pools are registered as private objects of the command buffer so
+    * they are destroyed when the command buffer is reset or destroyed (the
+    * same lifecycle as the meta descriptor pools above), which guarantees
+    * that pushed descriptor sets live for as long as any job recorded in the
+    * command buffer may reference them.
+    */
+   struct {
+      VkDescriptorPool dspool;
+
+      /* The currently active pushed descriptor set for each set index.
+       *
+       * Per the Vulkan spec, the descriptors set by vkCmdPushDescriptorSet
+       * persist and accumulate across multiple push calls to the same set
+       * number until they are disturbed (e.g. a regular vkCmdBindDescriptorSets
+       * to that set number). Applications are allowed to perform partial
+       * pushes that only update a subset of the bindings while relying on
+       * previously pushed bindings remaining valid.
+       *
+       * Because v3dv bakes descriptor state (texture/sampler HW state relocs)
+       * into the command list at draw-record time, we cannot mutate a pushed
+       * set in place once a draw has referenced it. Instead, every push
+       * allocates a fresh internal set (with its own region in the pool BO) and
+       * copies the previously accumulated contents forward before applying the
+       * new writes. These pointers track the last set pushed to each set index
+       * so we can source that copy-forward, and are invalidated (set to NULL)
+       * when a regular descriptor set is bound to the same set number.
+       */
+      struct v3dv_descriptor_set *sets[MAX_SETS];
+   } push_descriptor;
+
    /* List of jobs in the command buffer. For primary command buffers it
     * represents the jobs we want to submit to the GPU. For secondary command
     * buffers it represents jobs that will be merged into a primary command
diff --git a/src/broadcom/vulkan/v3dv_descriptor_set.c b/src/broadcom/vulkan/v3dv_descriptor_set.c
