diff --git a/src/broadcom/compiler/nir_to_vir.c b/src/broadcom/compiler/nir_to_vir.c
index 9bf4ec8e..cd0eaaa8 100644
--- a/src/broadcom/compiler/nir_to_vir.c
+++ b/src/broadcom/compiler/nir_to_vir.c
@@ -2592,6 +2592,36 @@ vir_emit_tlb_color_read(struct v3d_compile *c, nir_intrinsic_instr *instr)
          * switch instead -- see vir_emit_thrsw().
          */
         if (!c->emitted_tlb_load) {
+                /* Riscuoti i fetch TMU ancora in coda PRIMA di leggere il tile buffer.
+                 *
+                 * Su V3D un fetch e' asincrono: viene accodato e raccolto (con un thread
+                 * switch) solo al primo uso del risultato. Se quell'uso cade dopo una lettura
+                 * del tile buffer -- il caso tipico di uno shader che fonde col framebuffer e
+                 * campiona una texture -- il thread switch finisce dopo la lettura, e sopra
+                 * (vir_emit_thrsw) siamo costretti a lockare lo scoreboard sul PRIMO thread
+                 * switch invece che sull'ultimo. Il frammento tiene allora il pixel bloccato
+                 * per tutta la durata dei propri fetch, e i frammenti sovrapposti si
+                 * serializzano.
+                 *
+                 * Svuotando la coda qui, il thread switch torna a precedere la lettura e il
+                 * lock resta tardivo. Il lock viene comunque preso prima di ogni accesso al
+                 * tile buffer, come l'hardware richiede: cambia solo QUANDO si riscuotono i
+                 * fetch. Misurato su God of War II: fragment shader col lock anticipato da
+                 * 8/148 a 1/148.
+                 *
+                 * SPENTO DI DEFAULT (opt-in: V3D_TLB_FLUSH_FIRST=1). Elimina davvero la
+                 * serializzazione, ma NON conviene: riscuotere i fetch prima significa anche
+                 * aspettare la memoria prima, cioe' rinunciare al mascheramento della latenza,
+                 * che sul V3D e' tutto. Misurato: God of War II e Shadow of the Colossus
+                 * neutri, DRIV3R -8.5% (il piu' affamato di texture). Resta a disposizione per
+                 * carichi diversi (es. Dolphin, che legge il framebuffer molto piu' spesso).
+                 */
+                static int flush_first = -1;
+                if (flush_first < 0)
+                        flush_first = getenv("V3D_TLB_FLUSH_FIRST") ? 1 : 0;
+                if (flush_first)
+                        ntq_flush_tmu(c);
+
                 if (!c->last_thrsw_at_top_level)
                         vir_emit_thrsw(c);
 
diff --git a/src/broadcom/compiler/vir.c b/src/broadcom/compiler/vir.c
index ca06b450..17cbd101 100644
--- a/src/broadcom/compiler/vir.c
+++ b/src/broadcom/compiler/vir.c
@@ -945,6 +945,21 @@ v3d_fs_set_prog_data(struct v3d_compile *c,
                 c->uses_implicit_point_line_varyings;
         prog_data->lock_scoreboard_on_first_thrsw =
                 c->lock_scoreboard_on_first_thrsw;
+
+        /* V3D_SB_STATS=1: quanti fragment shader tengono il pixel bloccato per tutta la
+         * durata dei propri fetch (lock anticipato) contro quanti prendono il lock in fondo.
+         * E' la misura diretta della serializzazione imposta dagli shader che leggono il
+         * framebuffer: se un'applicazione ne ha molti, c'e' un premio da prendere.
+         */
+        if (unlikely(getenv("V3D_SB_STATS"))) {
+                static unsigned early, late;
+                if (c->lock_scoreboard_on_first_thrsw)
+                        early++;
+                else
+                        late++;
+                fprintf(stderr, "[v3d-sb] fs lock: early=%u late=%u (%.0f%% early)\n",
+                        early, late, 100.0 * early / (early + late));
+        }
         prog_data->force_per_sample_msaa = c->s->info.fs.uses_sample_shading;
         prog_data->uses_pid = c->fs_uses_primitive_id;
 }
